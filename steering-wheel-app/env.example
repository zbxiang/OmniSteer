JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_SECRET=omnisteer-password-key
DATABASE_URL=sqlite:///./omnisteer.db
# MySQL 本地（需先建库: CREATE DATABASE omnisteer CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;）
# 密码含特殊字符请做 URL 编码；驱动为 pymysql（requirements 已包含）
# DATABASE_URL=mysql+pymysql://root:你的密码@127.0.0.1:3306/omnisteer?charset=utf8mb4
# PostgreSQL 示例:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/omnisteer
DATABASE_ECHO=false
SEED_DEMO_USER=false
CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
